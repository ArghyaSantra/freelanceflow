generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum WorkspacePlan {
  FREE
  PRO
  AGENCY
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  EXPIRED
  CANCELLED
}

enum FieldType {
  SIGNATURE
  INITIALS
  DATE
  TEXT
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum ReminderType {
  DOCUMENT_PENDING
  DOCUMENT_EXPIRING
  INVOICE_BEFORE_7_DAYS
  INVOICE_BEFORE_3_DAYS
  INVOICE_OVERDUE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum AssetType {
  IMAGE
  VIDEO
}

enum AssetStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthorType {
  FREELANCER
  CLIENT
}

// ─── Models ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberOf      WorkspaceMember?
  refreshTokens RefreshToken[]
  client    Client?   // ← add to user relations


  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Workspace {
  id                String        @id @default(uuid())
  name              String
  logoUrl           String?       @map("logo_url")
  plan              WorkspacePlan @default(FREE)
  address           String?
  gstin             String?
  pan               String?
  bankName          String?       @map("bank_name")
  bankAccountNumber String?       @map("bank_account_number")
  bankIfsc          String?       @map("bank_ifsc")
  invoicePrefix     String        @default("INV") @map("invoice_prefix")
  invoiceFooter     String?       @map("invoice_footer")
  razorpayAccountId String?       @map("razorpay_account_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  members     WorkspaceMember[]
  clients     Client[]
  projects    Project[]
  invitations Invitation[]
  documents   Document[]
  invoices    Invoice[]
  reminders   Reminder[]
  assets      Asset[]   // ← add to workspace relations
  clientInvitations ClientInvitation[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  workspaceId String     @map("workspace_id")
  userId      String     @unique @map("user_id")
  role        MemberRole @default(MEMBER)
  invitedBy   String?    @map("invited_by")
  joinedAt    DateTime   @default(now()) @map("joined_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workspace_members")
}

model Invitation {
  id          String     @id @default(uuid())
  workspaceId String     @map("workspace_id")
  email       String
  role        MemberRole @default(MEMBER)
  token       String     @unique @default(uuid())
  invitedBy   String     @map("invited_by")
  expiresAt   DateTime   @map("expires_at")
  acceptedAt  DateTime?  @map("accepted_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@map("invitations")
}

model Project {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  clientId    String        @map("client_id")
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents Document[]
  invoices  Invoice[]
  assets    Asset[]   // ← add to project relations

  @@map("projects")
}

model Document {
  id            String         @id @default(uuid())
  workspaceId   String         @map("workspace_id")
  projectId     String         @map("project_id")
  title         String
  fileUrl       String         @map("file_url")
  signedFileUrl String?        @map("signed_file_url")
  status        DocumentStatus @default(DRAFT)
  publicToken   String         @unique @default(uuid()) @map("public_token")
  expiresAt     DateTime?      @map("expires_at")
  sentBy        String?        @map("sent_by")
  sentAt        DateTime?      @map("sent_at")
  signerIp      String?        @map("signer_ip")
  signerEmail   String?        @map("signer_email")
  signedAt      DateTime?      @map("signed_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentFields DocumentField[]
  reminders      Reminder[]

  @@map("documents")
}

model DocumentField {
  id         String    @id @default(uuid())
  documentId String    @map("document_id")
  type       FieldType @default(SIGNATURE)
  pageNumber Int       @map("page_number")
  x          Float
  y          Float
  width      Float
  height     Float
  createdAt  DateTime  @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_fields")
}

model Invoice {
  id                String        @id @default(uuid())
  workspaceId       String        @map("workspace_id")
  projectId         String        @map("project_id")
  invoiceNumber     String        @map("invoice_number")
  status            InvoiceStatus @default(DRAFT)
  issueDate         DateTime      @map("issue_date")
  dueDate           DateTime      @map("due_date")
  lineItems         Json          @map("line_items")
  subtotal          Float
  taxRate           Float         @default(0) @map("tax_rate")
  taxAmount         Float         @default(0) @map("tax_amount")
  total             Float
  currency          String        @default("INR")
  notes             String?
  sentBy            String?       @map("sent_by")
  sentAt            DateTime?     @map("sent_at")
  publicToken       String        @unique @default(uuid()) @map("public_token")
  paymentLink       String?       @map("payment_link")
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@unique([workspaceId, invoiceNumber])
  @@map("invoices")
}

model Reminder {
  id           String         @id @default(uuid())
  workspaceId  String         @map("workspace_id")
  invoiceId    String?        @map("invoice_id")
  documentId   String?        @map("document_id")
  type         ReminderType
  scheduledFor DateTime       @map("scheduled_for")
  sentAt       DateTime?      @map("sent_at")
  status       ReminderStatus @default(PENDING)
  createdAt    DateTime       @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  document  Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Client {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  email       String
  company     String?
  phone       String?
  address     String?
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  hasAccount  Boolean   @default(false) @map("has_account")  // ← add
  userId      String?   @unique @map("user_id")               // ← add
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  Project[]
  user      User?     @relation(fields: [userId], references: [id])  // ← add
  assets    Asset[]                                                    // ← add
  invitations ClientInvitation[]

  @@unique([workspaceId, email])
  @@map("clients")
}

model Asset {
  id          String      @id @default(uuid())
  workspaceId String      @map("workspace_id")
  projectId   String      @map("project_id")
  clientId    String      @map("client_id")
  title       String
  description String?
  fileUrl     String      @map("file_url")
  type        AssetType   @default(IMAGE)
  status      AssetStatus @default(PENDING)
  uploadedBy  String      @map("uploaded_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  comments  AssetComment[]

  @@map("assets")
}

model AssetComment {
  id         String     @id @default(uuid())
  assetId    String     @map("asset_id")
  authorId   String     @map("author_id")
  authorType AuthorType @map("author_type")
  content    String
  createdAt  DateTime   @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("asset_comments")
}

model ClientInvitation {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  clientId    String    @map("client_id")
  email       String
  token       String    @unique @default(uuid())
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_invitations")
}